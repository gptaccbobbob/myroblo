{
  "name": "myroblo",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Packages": {
        "$path": {
          "optional": "Packages"
        }
      }
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      },
      "ServerPackages": {
        "$path": {
          "optional": "ServerPackages"
        }
      }
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },
    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Size": [512, 1, 512],
          "Position": [0, -1, 0],
          "Color": [0.388, 0.372, 0.384],
          "Material": "Plastic",
          "Locked": true,
          "TopSurface": "Smooth",
          "BottomSurface": "Smooth"
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [0, 0, 0],
        "Brightness": 2,
        "GlobalShadows": true,
        "Technology": "ShadowMap"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    },
    "HttpService": {
      "$properties": {
        "HttpEnabled": true
      }
    }
  }
}
